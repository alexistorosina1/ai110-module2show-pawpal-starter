classDiagram
    class Owner {
        +str name
        +int available_mins
        +dict preferences
    }

    class Pet {
        +str name
        +str species
    }

    class Task {
        +str title
        +int duration
        +str priority
        +priority_rank() int
    }

    class Scheduler {
        +Owner owner
        +list~Task~ tasks
        +generate_plan() list
        +sort_tasks() list
        +filter_by_time() list
    }

    Owner "1" --> "1" Pet : owns
    Scheduler "1" --> "1" Owner : plans for
    Scheduler "1" --> "*" Task : schedules
